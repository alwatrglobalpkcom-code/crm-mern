# Required for production - set these in Hostinger Node.js app environment variables
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/crm?retryWrites=true&w=majority
JWT_SECRET=your-secret-key-min-32-chars-for-production

# Optional - Email (for reminders/notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=CRM <your-email@gmail.com>

# Optional - CORS (comma-separated origins, or leave empty for same-origin)
# CORS_ORIGIN=https://yourdomain.com
